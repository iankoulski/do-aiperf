#!/bin/bash

# These settings are required for any aiperf run
export ENDPOINT_URL=
export MODEL_NAME=
export TOKENIZER=

# Other settings
export ENDPOINT_TYPE=chat
export CONCURRENCY=10
export REQUEST_COUNT=100
export INPUT_TOKENS_MEAN=1024
export INPUT_TOKENS_STDEV=0
export OUTPUT_TOKENS_MEAN=512
export EXTRA_INPUTS="ignore_eos:true"
export RANDOM_SEED=42
